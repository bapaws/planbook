  "version": "0.2.0",
  "configurations": [
    {
      "name": "App Store",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": ["--target", "lib/main.dart"]
    },
    {
      "name": "Google Play",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": ["--target", "lib/main.dart", "--flavor", "store"]
    },
    {
      "name": "CN Store",
      "request": "launch",
      "type": "dart",
      "program": "lib/main_store.dart",
      "args": ["--target", "lib/main_store.dart","--flavor", "store"]
    },
    {
      "name": "Cloud",
      "request": "launch",
      "type": "dart",
      "program": "lib/main_cloud.dart",
      "args": ["--target", "lib/main_cloud.dart","--flavor", "cloud"]
    }
  ]
}
